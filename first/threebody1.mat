% % 关闭图形窗口（可选）
% close(fig);

%% 局部函数：三体运动微分方程
function dydt = threebody_ode(~, y, m, G)
    % y = [r1; r2; r3; v1; v2; v3] (列向量)
    r1 = y(1:3);
    r2 = y(4:6);
    r3 = y(7:9);
    v1 = y(10:12);
    v2 = y(13:15);
    v3 = y(16:18);
    % 相对位置
    r12 = r2 - r1;
    r13 = r3 - r1;
    r23 = r3 - r2;
    % 距离（避免除零）
    eps = 1e-13;
    d12 = max(norm(r12), eps);
    d13 = max(norm(r13), eps);
    d23 = max(norm(r23), eps);
    % 加速度（引力公式）
    a1 = G * ( m(2) * r12 / d12^3 + m(3) * r13 / d13^3 );
    a2 = G * ( m(1) * (-r12) / d12^3 + m(3) * r23 / d23^3 );
    a3 = G * ( m(1) * (-r13) / d13^3 + m(2) * (-r23) / d23^3 );
    % 组装导数
    dydt = [v1; v2; v3; a1; a2; a3];
end

%% 局部函数：定步长四阶龙格-库塔积分器
function [t, y] = rk4_fixed(odefun, tspan, y0, h)
    % 输入：
    %   odefun - 函数句柄，形式 dydt = odefun(t, y) （y 为列向量）
    %   tspan  - 积分区间 [t0, tf]
    %   y0     - 初始状态向量（列向量或行向量）
    %   h      - 固定步长
    % 输出：
    %   t      - 时间列向量，t = t0 : h : t0+n*h，其中 n = floor((tf-t0)/h)
    %   y      - 状态矩阵，每行对应一个时间点，每列对应一个状态分量
    t0 = tspan(1);
    tf = tspan(2);
    n = floor((tf - t0) / h);          % 总步数（忽略末尾不足一部的部分）
    t = t0 + (0:n)' * h;               % 时间列向量
    y = zeros(n+1, length(y0));        % 预分配输出矩阵
    y(1,:) = y0(:)';                   % 第一行赋初值
    yi = y0(:);                         % 当前状态（列向量）
    for i = 1:n
        ti = t(i);
        % 计算四个斜率
        K1 = odefun(ti, yi);
        K2 = odefun(ti + h/2, yi + h/2 * K1);
        K3 = odefun(ti + h/2, yi + h/2 * K2);
        K4 = odefun(ti + h, yi + h * K3);
        % 更新状态（四阶龙格-库塔公式）
        yi = yi + h/6 * (K1 + 2*K2 + 2*K3 + K4);
        % 存储当前步结果
        y(i+1, :) = yi';
    end
end
