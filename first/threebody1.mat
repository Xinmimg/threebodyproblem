clear; clc; close all;
%% 参数设置
G = 1;              % 引力常数
m = [1, 1, 1];      % 三个物体的质量相等
%% 初始条件
r1_0 = [1.001, 0, 1];      % 增加微小的 z 分量使运动真正三维
r2_0 = [-0.5, sqrt(3)/2, -0.05];
r3_0 = [-0.5, -sqrt(3)/2, 0.05];
% 初始速度：使系统绕质心逆时针旋转
v1_0 = [0, 1, 0.1];
v2_0 = [-sqrt(3)/2, -0.5, -0.05];
v3_0 = [sqrt(3)/2, -0.5, 0.05];
% 合并初始状态向量 [r1; r2; r3; v1; v2; v3] (18 维)
y0 = [r1_0, r2_0, r3_0, v1_0, v2_0, v3_0]';
%% 时间跨度
tspan = [0 5000];     % 可调整时长以观察不同行为
%% 数值积分
% options = odeset('RelTol',1e-5,'Stats','on','OutputFcn',@odeplot);
% [t, y] = ode45(@(t, y) threebody_ode(t, y, m, G), tspan, y0,options);
%% 数值积分（使用定步长四阶龙格-库塔方法）
h_fixed = 0.01; % 固定步长（可根据需要调整，例如 0.05 或 0.01）
[t, y] = rk4_fixed(@(t, y) threebody_ode(t, y, m, G), tspan, y0, h_fixed);
%% 提取位置坐标
r1 = y(:, 1:3);
r2 = y(:, 4:6);
r3 = y(:, 7:9);
%% ================= 三维静态轨迹图 =================
figure;
hold on;
plot3(r1(:,1), r1(:,2), r1(:,3), 'r', 'LineWidth', 1.5);   % 物体1轨迹
plot3(r2(:,1), r2(:,2), r2(:,3), 'g', 'LineWidth', 1.5);   % 物体2轨迹
plot3(r3(:,1), r3(:,2), r3(:,3), 'b', 'LineWidth', 1.5);   % 物体3轨迹
% 标记初始位置
plot3(r1(1,1), r1(1,2), r1(1,3), 'ro', 'MarkerSize', 8, 'MarkerFaceColor', 'r');
plot3(r2(1,1), r2(1,2), r2(1,3), 'go', 'MarkerSize', 8, 'MarkerFaceColor', 'g');
plot3(r3(1,1), r3(1,2), r3(1,3), 'bo', 'MarkerSize', 8, 'MarkerFaceColor', 'b');
xlabel('x'); ylabel('y'); zlabel('z');
title('三体运动轨迹（三维）');
legend('物体1', '物体2', '物体3');
axis equal;         % 等比例坐标轴
grid on;
view(3);            % 三维视角
hold off;
%% ================= 三维 MP4 动画生成 =================
% 设置输出文件名
video_filename = 'three_body_3d.mp4';
% 帧率控制：取总时间点的 1/20 作为帧数，最多 2000 帧（与原GIF相同）
num_frames = min(2000, floor(length(t)/20));
frame_idx = round(linspace(1, length(t), num_frames)); % 待绘制的帧索引
% 计算所有位置的全局范围，固定坐标轴（包含 z）
all_x = [r1(:,1); r2(:,1); r3(:,1)];
all_y = [r1(:,2); r2(:,2); r3(:,2)];
all_z = [r1(:,3); r2(:,3); r3(:,3)];
x_min = min(all_x); x_max = max(all_x);
y_min = min(all_y); y_max = max(all_y);
z_min = min(all_z); z_max = max(all_z);
% 扩展 10% 范围，避免物体贴边
x_range = x_max - x_min; if x_range==0, x_range=1; end
y_range = y_max - y_min; if y_range==0, y_range=1; end
z_range = z_max - z_min; if z_range==0, z_range=1; end
x_lim = [x_min - 0.1*x_range, x_max + 0.1*x_range];
y_lim = [y_min - 0.1*y_range, y_max + 0.1*y_range];
z_lim = [z_min - 0.1*z_range, z_max + 0.1*z_range];

% 创建新图形窗口用于视频
fig = figure('Position', [100 100 800 600]);
% 初始化坐标轴
ax = gca;
hold on; axis equal; grid on;
xlim(x_lim); ylim(y_lim); zlim(z_lim);
xlabel('x'); ylabel('y'); zlabel('z');
title('三体动画（三维）');
view(3);            % 三维视角
% 初始化三维轨迹线（空线条）和当前位置标记
h1_traj = plot3(nan, nan, nan, 'r', 'LineWidth', 1.5);   % 物体1轨迹
h2_traj = plot3(nan, nan, nan, 'g', 'LineWidth', 1.5);   % 物体2轨迹
h3_traj = plot3(nan, nan, nan, 'b', 'LineWidth', 1.5);   % 物体3轨迹
h1_mark = plot3(nan, nan, nan, 'ro', 'MarkerSize', 8, 'MarkerFaceColor', 'r');
h2_mark = plot3(nan, nan, nan, 'go', 'MarkerSize', 8, 'MarkerFaceColor', 'g');
h3_mark = plot3(nan, nan, nan, 'bo', 'MarkerSize', 8, 'MarkerFaceColor', 'b');
% 添加图例（只显示轨迹线）
legend([h1_traj, h2_traj, h3_traj], {'物体1','物体2','物体3'});
% 创建 VideoWriter 对象，设置帧率为 10 帧/秒（与 GIF 的 DelayTime 0.1 秒一致）
v = VideoWriter(video_filename, 'MPEG-4');
v.FrameRate = 10;
open(v);
% 循环生成每一帧
for k = 1:length(frame_idx)
    i = frame_idx(k);   % 当前帧对应的原始数据索引
    % 更新轨迹线数据（从起点到当前点）- 需设置 XData, YData, ZData
    set(h1_traj, 'XData', r1(1:i,1), 'YData', r1(1:i,2), 'ZData', r1(1:i,3));
    set(h2_traj, 'XData', r2(1:i,1), 'YData', r2(1:i,2), 'ZData', r2(1:i,3));
    set(h3_traj, 'XData', r3(1:i,1), 'YData', r3(1:i,2), 'ZData', r3(1:i,3));
    % 更新当前位置标记
    set(h1_mark, 'XData', r1(i,1), 'YData', r1(i,2), 'ZData', r1(i,3));
    set(h2_mark, 'XData', r2(i,1), 'YData', r2(i,2), 'ZData', r2(i,3));
    set(h3_mark, 'XData', r3(i,1), 'YData', r3(i,2), 'ZData', r3(i,3));
    % 更新标题显示当前时间
    title(ax, sprintf('三体动画, t = %.2f', t(i)));
    % 刷新图形
    drawnow;
    % 捕获当前帧图像并写入视频
    frame = getframe(fig);
    writeVideo(v, frame.cdata);
end

% 关闭视频文件和图形窗口
close(v);
close(fig);
