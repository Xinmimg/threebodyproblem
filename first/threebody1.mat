% 
% % 创建新图形窗口用于 GIF
% fig = figure('Position', [100 100 800 600]);
% % 初始化坐标轴
% ax = gca;
% hold on; axis equal; grid on;
% xlim(x_lim); ylim(y_lim); zlim(z_lim);
% xlabel('x'); ylabel('y'); zlabel('z');
% title('三体动画（三维）');
% view(3);            % 三维视角
% 
% % 初始化三维轨迹线（空线条）和当前位置标记
% h1_traj = plot3(nan, nan, nan, 'r', 'LineWidth', 1.5);   % 物体1轨迹
% h2_traj = plot3(nan, nan, nan, 'g', 'LineWidth', 1.5);   % 物体2轨迹
% h3_traj = plot3(nan, nan, nan, 'b', 'LineWidth', 1.5);   % 物体3轨迹
% h1_mark = plot3(nan, nan, nan, 'ro', 'MarkerSize', 8, 'MarkerFaceColor', 'r');
% h2_mark = plot3(nan, nan, nan, 'go', 'MarkerSize', 8, 'MarkerFaceColor', 'g');
% h3_mark = plot3(nan, nan, nan, 'bo', 'MarkerSize', 8, 'MarkerFaceColor', 'b');
% 
% % 添加图例（只显示轨迹线）
% legend([h1_traj, h2_traj, h3_traj], {'物体1','物体2','物体3'});
% 
% % 循环生成每一帧
% for k = 1:length(frame_idx)
%     i = frame_idx(k);   % 当前帧对应的原始数据索引
%     
