%     [A, map] = rgb2ind(im, 256);   % 转换为索引图像
%     
%     % 写入 GIF 文件
%     if k == 1
%         imwrite(A, map, gif_filename, 'gif', 'LoopCount', Inf, 'DelayTime', 0.1);
%     else
%         imwrite(A, map, gif_filename, 'gif', 'WriteMode', 'append', 'DelayTime', 0.1);
%     end
% end
